generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

enum UserRole {
  CLIENT
  BARBER
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

model User {
  id                   String        @id @default(cuid())
  name                 String
  email                String        @unique
  phone                String?
  passwordHash         String
  sessionVersion       Int           @default(0)
  role                 UserRole      @default(CLIENT)
  barberProfile        BarberProfile?
  appointments         Appointment[] @relation("ClientAppointments")
  canceledAppointments Appointment[] @relation("CanceledAppointments")
  createdInvites       RegistrationInvite[] @relation("InviteCreator")
  acceptedInvite       RegistrationInvite?  @relation("InviteUser")
  passwordResetTokens  PasswordResetToken[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@map("users")
}

model RegistrationInvite {
  id          String    @id @default(cuid())
  codeHash    String    @unique
  codeHint    String
  role        UserRole
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  usedById    String?   @unique
  usedBy      User?     @relation("InviteUser", fields: [usedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([role, expiresAt])
  @@index([createdById])
  @@map("registration_invites")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model BarberProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio            String?
  phone          String?
  specialty      String?
  active         Boolean        @default(true)
  availabilities Availability[]
  appointments   Appointment[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("barber_profiles")
}

model Service {
  id              String        @id @default(cuid())
  name            String
  description     String?
  durationMinutes Int
  price           Decimal       @db.Decimal(10, 2)
  active          Boolean       @default(true)
  appointments    Appointment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("services")
}

model Availability {
  id               String        @id @default(cuid())
  barberId         String
  barber           BarberProfile @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek        Int
  startTimeMinutes Int
  endTimeMinutes   Int
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([barberId, dayOfWeek, startTimeMinutes, endTimeMinutes])
  @@index([barberId, dayOfWeek])
  @@map("availabilities")
}

model Appointment {
  id                 String            @id @default(cuid())
  clientId           String
  client             User              @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Restrict)
  barberId           String
  barber             BarberProfile     @relation(fields: [barberId], references: [id], onDelete: Restrict)
  serviceId          String
  service            Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  startsAt           DateTime
  endsAt             DateTime
  status             AppointmentStatus @default(SCHEDULED)
  notes              String?
  cancellationReason String?
  canceledAt         DateTime?
  canceledById       String?
  canceledBy         User?             @relation("CanceledAppointments", fields: [canceledById], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([clientId, startsAt])
  @@index([barberId, startsAt])
  @@index([serviceId])
  @@index([status])
  @@map("appointments")
}
